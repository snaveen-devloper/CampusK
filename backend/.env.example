# CampusKarma — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!

# ─── MongoDB ─────────────────────────────────────────────────────────────────
# Local dev: mongodb://localhost:27017/campuskarma
# Production (Atlas): mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/campuskarma
MONGO_URL=mongodb://localhost:27017/campuskarma

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Any long random string — used to sign auth tokens
JWT_SECRET=change_this_to_a_long_random_secret_string

# ─── AI (optional) ───────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
